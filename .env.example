APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_ENABLE_STARTER_DATA=true
WEB_APP_URL=http://localhost
MOBILE_APP_URL=http://localhost:8100
MOBILE_API_URL=http://localhost/api/v1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_EXPIRATION=
SANCTUM_TOKEN_PREFIX=vag_
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8100,127.0.0.1,127.0.0.1:8000,127.0.0.1:8100,::1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1:8000,http://localhost:8100,http://127.0.0.1:8100,capacitor://localhost,ionic://localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=failover
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google OAuth
# 1) Create OAuth credentials in Google Cloud Console
# 2) Add the redirect URI: ${APP_URL}/auth/google/callback
# 3) Use the same base host everywhere: APP_URL, GOOGLE_REDIRECT_URI, Google Cloud
#    and the browser must all use localhost or all use 127.0.0.1
# 4) On Windows, if PHP reports SSL certificate errors against Google, configure
#    curl.cainfo and openssl.cafile in php.ini with a valid cacert.pem bundle
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

VITE_APP_NAME="${APP_NAME}"
